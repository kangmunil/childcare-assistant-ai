# ========================================
# Supabase 설정
# ========================================
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here  # 서버 사이드에서만 사용

# ========================================
# 공공데이터포털 API Keys
# ========================================
# 공공데이터포털 (data.go.kr)에서 발급받은 인증키
DATA_GO_KR_API_KEY=your_data_go_kr_service_key

# 어린이집 정보 조회 서비스
CHILDCARE_API_KEY=your_childcare_api_key

# 국립중앙의료원 - 달빛어린이병원
MOONLIGHT_HOSPITAL_API_KEY=your_moonlight_hospital_api_key

# 질병관리청 - 예방접종 위탁의료기관
KDCA_VACCINE_API_KEY=your_kdca_vaccine_api_key

# ========================================
# 데이터 파일 경로
# ========================================
# 질병관리청 성장도표 LMS 데이터 파일
GROWTH_CHART_FILE_PATH=./data/growth_standards/kdca_growth_chart_2017.xlsx

# 예방접종 일정 데이터
VACCINE_SCHEDULE_FILE_PATH=./data/vaccine_schedule/nip_schedule.csv

# ========================================
# 로깅 설정
# ========================================
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/app.log

# ========================================
# 데이터 수집 설정
# ========================================
# API 요청 간격 (초) - 서버 부하 방지
API_REQUEST_DELAY=1.0

# 배치 크기
BATCH_SIZE=100

# ========================================
# AI/LLM 설정
# ========================================
# OpenAI API 키 (GPT-4, Embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# LLM 모델 선택
LLM_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# Temperature (0.0~1.0, 낮을수록 일관성, 높을수록 창의성)
LLM_TEMPERATURE=0.7

# ========================================
# Vector Database 설정
# ========================================
# ChromaDB 저장 경로
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Vector 검색 결과 개수
VECTOR_SEARCH_TOP_K=5
