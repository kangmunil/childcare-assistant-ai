# === LLM Settings (OpenRouter 권장) ===
# 필수: OpenRouter API Key
OPENROUTER_API_KEY=sk-or-v1-...

# 모델 설정
LLM_MODEL=google/gemini-2.0-flash-exp:free
EMBEDDING_MODEL=google/gemini-embedding-001

# OpenRouter Base URL (기본값: https://openrouter.ai/api/v1)
# 특별한 이유가 없다면 변경하지 마세요.
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# === Legacy / Direct OpenAI Usage ===
# OpenAI를 직접 사용할 경우에만 주석을 해제하고 사용하세요.
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1

# === Database ===
# RAG 벡터 DB 저장 경로
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# SQLite DB 경로
SQLITE_DB_PATH=data/childcare.db

# Supabase (Optional)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/app.log

# === FastAPI Chat Meta ===
# 챗봇 응답 meta 생성 on/off
AI_CHAT_META_ENABLED=true
